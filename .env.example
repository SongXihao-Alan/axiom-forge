# Copy this file to .env and fill in your real key
# Basic CLI commands (list/query/search/show) do NOT require a key.
# M3-powered commands (ask/explore-anchor/validate) DO require a key.

# ──────────────────────────────────────────────────────────────────────
# ⚠️  SECURITY WARNING
# ──────────────────────────────────────────────────────────────────────
# 1. If your MINIMAX_API_KEY was EVER shared (chat, screenshot, repo,
#    paste), REVOKE it FIRST at https://api.minimaxi.com/user/secret-key
#    before generating a new one.
# 2. .env is in .gitignore — never force-add it. Verify with:
#       git check-ignore -v .env
#       # should print: .gitignore:<line>:.env  .env
# 3. After editing .env, run:  git status  — .env must NOT appear.
# 4. The axiom-forge.bundle file in older snapshots may contain an old
#    key; delete it if you find one.
# ──────────────────────────────────────────────────────────────────────

MINIMAX_API_KEY=sk-cp-replace-me-with-real-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3