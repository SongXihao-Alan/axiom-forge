# Secrets & venv
.env
.venv/
venv/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# OS
**/.DS_Store
/.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# Python packaging
*.egg-info/
dist/
build/

# Outputs (keep only v0.3-alpha deliverables)
outputs/*.json
outputs/*.md
!outputs/.gitkeep
!outputs/v0.2_shap/
!outputs/v0.2/

# Literature ingest intermediate (regenerated each run)
kb/ingest/candidates.json
kb/ingest/drafts*/
kb/ingest/snapshots/
kb/ingest/candidates_*.json

# Lane B evaluator predictions (regenerated each run)
paper/results/
kb/ingest/lane_b_predictions.json

# Lean 4 build cache (regenerated by `lake build`)
formal/.lake/
formal/build/
formal/lake-packages/

# Lean 4 auto-generated proofs (regenerated by proof_checker.py)
formal/AxiomForge/Generated/

# Documentation (keep only v0.3-alpha final)
docs/*.md
!docs/v0.3-alpha/
!docs/PROCESS_NARRATIVE.md

# Backup of real key — never commit
.env.real_key_backup
.env.*
!/.env.example
*.bundle

# Tencent Cloud SSH key for web deployment (deployment-only; never share)
/deploy/*.pem
!/deploy/.gitkeep
